---
import { SITE, NAV_LINKS, CTA } from '../consts';
---

<footer class="border-t border-surface-100 dark:border-dark-border bg-surface-950 text-surface-200">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-white">
          <svg class="h-7 w-7 text-primary-400" viewBox="0 0 32 32" fill="none">
            <rect width="32" height="32" rx="8" fill="currentColor" />
            <path d="M9 12a2 2 0 012-2h10a2 2 0 012 2v6a2 2 0 01-2 2h-3l-3 3-3-3H11a2 2 0 01-2-2v-6z" fill="white" />
            <circle cx="13" cy="15" r="1.5" fill="currentColor" />
            <circle cx="19" cy="15" r="1.5" fill="currentColor" />
          </svg>
          {SITE.name}
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-surface-200/60">
          Mine Chatbot thông minh cho shop online Việt Nam. Tự động chốt đơn 24/7.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-white">Sản phẩm</h3>
        <ul class="space-y-3">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-surface-200/60 transition-colors hover:text-white">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-white">Bắt đầu</h3>
        <ul class="space-y-3">
          <li>
            <a href={CTA.trial.href} class="text-sm text-surface-200/60 transition-colors hover:text-white">
              {CTA.trial.label}
            </a>
          </li>
          <li>
            <a href={CTA.login.href} class="text-sm text-surface-200/60 transition-colors hover:text-white">
              {CTA.login.label}
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-white">Liên hệ</h3>
        <ul class="space-y-3">
          <li>
            <a href="mailto:support@aichatbot.vn" class="text-sm text-surface-200/60 transition-colors hover:text-white">
              support@aichatbot.vn
            </a>
          </li>
          <li>
            <span class="text-sm text-surface-200/60">Hỗ trợ qua chat 24/7</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-surface-200/10 pt-8 md:flex-row">
      <p class="text-xs text-surface-200/40">
        &copy; {new Date().getFullYear()} {SITE.name}. Made with ❤️ in Vietnam.
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-xs text-surface-200/40 transition-colors hover:text-white">
          Chính sách bảo mật
        </a>
        <a href="/terms" class="text-xs text-surface-200/40 transition-colors hover:text-white">
          Điều khoản sử dụng
        </a>
      </div>
    </div>
  </div>
</footer>
