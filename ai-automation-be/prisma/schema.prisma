generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ============================================
// Auth & Multi-tenancy
// ============================================

model Seller {
  id        String   @id @default(uuid())
  // Supabase Auth user ID — liên kết với JWT sub claim
  authId    String   @unique @map("auth_id")
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenants Tenant[]

  @@map("sellers")
}

model Tenant {
  id           String   @id @default(uuid())
  sellerId     String   @map("seller_id")
  name         String
  slug         String   @unique
  messageQuota Int      @default(1000) @map("message_quota")
  messageUsed  Int      @default(0) @map("message_used")
  settings     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  seller             Seller              @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  agents             Agent[]
  channelConnections ChannelConnection[]
  knowledgeDocuments KnowledgeDocument[]
  conversations      Conversation[]

  @@index([sellerId])
  @@map("tenants")
}

// ============================================
// Agent (AI Bot Configuration)
// ============================================

model Agent {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  persona     String   @default("Bạn là trợ lý bán hàng thân thiện, chuyên nghiệp. Trả lời bằng tiếng Việt, ngắn gọn, hữu ích.")
  greeting    String   @default("Xin chào! Tôi có thể giúp gì cho bạn?")
  model       String   @default("gpt-4o-mini")
  temperature Float    @default(0.7)
  maxTokens   Int      @default(500) @map("max_tokens")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([tenantId])
  @@map("agents")
}

// ============================================
// Channel (Facebook Messenger, etc.)
// ============================================

enum ChannelType {
  FACEBOOK
  ZALO
  WIDGET
}

model ChannelConnection {
  id               String      @id @default(uuid())
  tenantId         String      @map("tenant_id")
  channelType      ChannelType @map("channel_type")
  // FB: page ID
  externalId       String      @map("external_id")
  externalName     String?     @map("external_name")
  // Encrypted access token (AES-256)
  accessTokenEnc   String?     @map("access_token_enc")
  isActive         Boolean     @default(true) @map("is_active")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([channelType, externalId])
  @@index([tenantId])
  @@map("channel_connections")
}

// ============================================
// Knowledge Base (RAG)
// ============================================

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

model KnowledgeDocument {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  fileName     String         @map("file_name")
  fileType     String         @map("file_type")
  fileSize     Int            @map("file_size")
  status       DocumentStatus @default(PENDING)
  errorMessage String?        @map("error_message")
  chunkCount   Int            @default(0) @map("chunk_count")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]

  @@index([tenantId])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id         String                    @id @default(uuid())
  documentId String                    @map("document_id")
  content    String
  // pgvector: 1536 dimensions (text-embedding-3-small)
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int                       @map("chunk_index")
  metadata   Json                      @default("{}")
  createdAt  DateTime                  @default(now()) @map("created_at")

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("knowledge_chunks")
}

// ============================================
// Conversation & Messages
// ============================================

enum MessageRole {
  CUSTOMER
  ASSISTANT
  SYSTEM
}

model Conversation {
  id                    String   @id @default(uuid())
  tenantId              String   @map("tenant_id")
  agentId               String   @map("agent_id")
  // Channel-specific conversation ID (FB sender_id, etc.)
  channelConversationId String?  @map("channel_conversation_id")
  channelType           ChannelType? @map("channel_type")
  customerName          String?  @map("customer_name")
  lastMessageAt         DateTime? @map("last_message_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([tenantId, channelType, channelConversationId])
  @@index([tenantId, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        String
  tokenCount     Int?        @map("token_count")
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}
