  "tech_stack": {
    "backend": {
      "runtime": "Node.js 20+",
      "framework": "NestJS 11",
      "orm": "Prisma 7.7 (PrismaPg adapter)",
      "database": "Supabase PostgreSQL + pgvector",
      "auth": "Supabase Auth (JWT)",
      "llm": "OpenAI-compatible (Gemini via openai SDK)",
      "source_file": "ai-automation-be/package.json"
    },
    "frontend": {
      "framework": "Next.js 15 (App Router)",
      "state": "Zustand",
      "ui": "Tailwind CSS + Lucide icons",
      "auth": "Supabase Auth (@supabase/ssr)",
      "source_file": "ai-automation-fe/package.json"
    }
  },

  "database_schema": {
    "key_models": [
      "Seller", "Tenant", "TenantMember", "Agent", "Customer",
      "Conversation", "Message", "KnowledgeFile", "KnowledgeChunk",
      "ChannelConnection"
    ],
    "conversation_statuses": ["BOT_HANDLING", "OPEN", "SNOOZED", "RESOLVED"],
    "message_roles": ["CUSTOMER", "ASSISTANT", "SYSTEM", "HUMAN_AGENT", "TOOL"],
    "channel_types": ["FACEBOOK"],
    "source_file": "ai-automation-be/prisma/schema.prisma",
    "last_verified_sha": "074f3d88a8a61375f688570170a91a063883b4eb"
  },

  "api_endpoints": {
    "auth": ["POST /auth/register", "POST /auth/login", "GET /auth/me"],
    "tenants": ["POST /tenants", "GET /tenants", "POST /tenants/:id/members"],
    "agents": ["POST /tenants/:id/agents", "GET /tenants/:id/agents", "PATCH /tenants/:id/agents/:agentId", "DELETE /tenants/:id/agents/:agentId"],
    "conversations": [
      "POST /tenants/:id/chat",
      "POST /tenants/:id/chat/test",
      "GET /tenants/:id/conversations",
      "GET /tenants/:id/conversations/:convId/messages",
      "PATCH /tenants/:id/conversations/:convId/resolve",
      "POST /tenants/:id/conversations/:convId/human-reply",
      "PATCH /tenants/:id/conversations/:convId/handover-bot"
    ],
    "knowledge": [
      "POST /tenants/:id/knowledge/upload",
      "GET /tenants/:id/knowledge",
      "DELETE /tenants/:id/knowledge/:fileId"
    ],
    "channels": [
      "POST /tenants/:id/channels/facebook/connect",
      "GET /tenants/:id/channels",
      "DELETE /tenants/:id/channels/facebook/disconnect"
    ],
    "webhooks": [
      "GET /webhook/facebook (verification)",
      "POST /webhook/facebook (events)"
    ],
    "last_verified_sha": "074f3d88a8a61375f688570170a91a063883b4eb"
  },

  "features": {
    "phase_01_project_init": { "status": "done" },
    "phase_02_database_auth": { "status": "done" },
    "phase_03_tenant_agent_crud": { "status": "done" },
    "phase_04_llm_integration": { "status": "done" },
    "phase_05_agent_pipeline": { "status": "done" },
    "phase_06_conversation_memory": { "status": "done" },
    "phase_07_knowledge_upload": { "status": "done" },
    "phase_08_knowledge_search_rag": { "status": "done" },
    "phase_09_facebook_channel": { "status": "done", "last_changed_sha": "074f3d88a8a61375f688570170a91a063883b4eb" },
    "phase_10_selfserve_polish": { "status": "not_started" },
    "phase_11_testing_hardening": { "status": "not_started" }
  },

  "business_rules": [
    "Conversation status OPEN = nhân viên đang xử lý, bot không reply",
    "Human agent reply tự động chuyển status → OPEN",
    "Handover-to-bot chuyển status → BOT_HANDLING + ghi SYSTEM message audit",
    "Message dedup bằng in-memory Map (TTL 5 phút) — cần Redis khi multi-instance",
    "FB webhook phải respond 200 trong 5s, xử lý async",
    "Quota check: tenant.messageUsed >= tenant.messageQuota → reject"
  ],

  "coding_conventions": {
    "backend": "NestJS + Prisma, ESLint flat config, Prettier, no semicolons (Prettier default)",
    "frontend": "Next.js App Router, Zustand stores, Tailwind CSS, Lucide icons",
    "commit_format": "Conventional Commits (feat/fix/docs/chore)"
  }
}
